      "import": "./dist/services/CommandService.js"
    },
    "./services/ConfigService": {
      "development": "./src/services/ConfigService.ts",
      "types": "./dist/services/ConfigService.d.ts",
      "import": "./dist/services/ConfigService.js"
    },
    "./services/ExeDevService": {
      "development": "./src/services/ExeDevService.ts",
