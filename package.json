{
  "name": "threadvm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:stable": "turbo dev:stable",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "probe:terminal": "pnpm build && pnpm probe:boundaries && pnpm probe:web-style && node scripts/terminal_probe.mjs && pnpm probe:terminal-ui",
    "probe:boundaries": "pnpm exec tsx scripts/workspace_boundary_probe.ts",
    "probe:dev": "node scripts/dev_probe.mjs",
    "probe:web-style": "pnpm exec tsx scripts/web_style_probe.ts",
    "probe:terminal-ui": "pnpm exec tsx --tsconfig apps/web/tsconfig.json scripts/terminal_ui_probe.ts",
    "start": "pnpm --filter @threadvm/server start"
  },
  "devDependencies": {
    "tsx": "^4.23.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  }
}
