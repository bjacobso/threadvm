{
  "name": "@threadvm/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/main.ts",
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--conditions=development tsx watch src/main.ts",
    "dev:stable": "pnpm run build && node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.94",
    "@threadvm/shared": "workspace:*",
    "effect": "^4.0.0-beta.94"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.23.0"
  }
}
