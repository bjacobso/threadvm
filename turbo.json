{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["THREADVM_PORT", "THREADVM_WEB_PORT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:stable": {
      "cache": false,
      "persistent": true
    }
  }
}
