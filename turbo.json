{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "HARNESS_CONFIG",
    "THREADVM_PORT",
    "THREADVM_PROJECT_DIR",
    "THREADVM_PROJECTS_FILE",
    "THREADVM_WEB_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:stable": {
      "cache": false,
      "persistent": true
    }
  }
}
